# Get your free Mapbox token at: https://account.mapbox.com/auth/signup/
# Token should start with "pk."
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiZGV2dGVzdCIsImEiOiJjazAwMDAwMDAwIn0.your_token_here

# API base URL - change if backend is at different location
NEXT_PUBLIC_API_BASE=http://localhost:8000

# YouTube Data API key for song search
YOUTUBE_API_KEY=your_youtube_api_key
