DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/pollarsteps
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE-ME-generate-a-real-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
AI_CHRONICLER_URL=

# Gemini API — used for Ask Questions / recommendations
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Email Configuration (for signup notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Pollarsteps
